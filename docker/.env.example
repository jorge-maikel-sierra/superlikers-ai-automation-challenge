# ============================================
# n8n Configuration
# ============================================
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678

# ============================================
# MCP Server (Model Context Protocol)
# ============================================
N8N_MCP_ACCESS_ENABLED=true
# N8N_MCP_MANAGED_BY_ENV=true     # Lock MCP config from env (optional)

# ============================================
# Superlikers API
# ============================================
SUPERLIKERS_API_KEY=your_api_key_here
SUPERLIKERS_BASE_URL=https://api.superlikerslabs.com/v1
SUPERLIKERS_CAMPAIGN=3z

# ============================================
# AI Provider (OpenAI)
# ============================================
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# Optional: Alternative AI Provider (Claude)
# ============================================
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================
# WhatsApp Cloud API
# ============================================
WHATSAPP_TOKEN=your_whatsapp_token_here
# WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
# WHATSAPP_VERIFY_TOKEN=your_verify_token_here

# ============================================
# WhatsApp Validation (Phone Validator Node)
# ============================================
COUNTRY_CODE=57
PHONE_DIGITS=10

# ============================================
# Activity Configuration
# ============================================
SUPERLIKERS_ACTIVITY_ID=your_activity_id_here
